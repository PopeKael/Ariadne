# ===========================================
# Ariadne KnowledgeVault
# Git Ignore
# ===========================================

# -------------------------------------------
# Ignore everything by default
# -------------------------------------------
*

# Allow Git to traverse directories
!*/

# -------------------------------------------
# Keep project infrastructure
# -------------------------------------------
!.gitignore
!README.md

# -------------------------------------------
# Ariadne Engine
# -------------------------------------------
!00_System/
!00_System/**

# -------------------------------------------
# Documentation
# -------------------------------------------
!docs/
!docs/**

# -------------------------------------------
# Obsidian Vault Configuration
# Keep only vault settings, not personal layout
# -------------------------------------------
!.obsidian/
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/core-plugins.json
!.obsidian/graph.json

# Ignore personal workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# -------------------------------------------
# User Knowledge (never committed)
# -------------------------------------------
Archive/**
Concepts/**
Entities/**
Inbox/**
Journal/**
Log/**
People/**
Processed/**
Projects/**
Review/**
Sources/**

# -------------------------------------------
# Windows junk
# -------------------------------------------
Thumbs.db
Desktop.ini