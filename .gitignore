# ==========================================================
# KnowledgeVault - Git Ignore
# ==========================================================

# ----------------------------------------------------------
# Obsidian local workspace
# ----------------------------------------------------------

.obsidian/workspace.json

# ----------------------------------------------------------
# Ignore private knowledge contents
# Keep folder structure and README.md files
# ----------------------------------------------------------

Archive/**
!Archive/README.md

Inbox/**
!Inbox/README.md

Journal/**
!Journal/README.md

Processed/**
!Processed/README.md

Review/**
!Review/README.md

People/**
!People/README.md

Entities/**
!Entities/README.md

Sources/**
!Sources/README.md

Concepts/**
!Concepts/README.md

Log/**
!Log/README.md

# ----------------------------------------------------------
# Everything under Projects is PUBLIC
# ----------------------------------------------------------

# (No ignore rules)

# ----------------------------------------------------------
# System files
# ----------------------------------------------------------

Thumbs.db
.DS_Store
*.tmp
*.bak
*.log

